#!/bin/sh

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Collect staged files (excluding deletions)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d)

# ── Biome: lint + format check for JS/TS files (exclude crates/) ──
JS_FILES=$(echo "$STAGED_FILES" | grep -v '^crates/' | grep -E '\.(js|jsx|ts|tsx|json|jsonc|css)$' || true)

if [ -n "$JS_FILES" ]; then
  echo "JS/TS changes detected — running Biome checks..."

  if command -v biome >/dev/null 2>&1; then
    echo "$JS_FILES" | xargs biome check --no-errors-on-unmatched 2>&1
    if [ $? -ne 0 ]; then
      echo "Biome: lint/format errors found. Run 'biome check --write' to fix."
      exit 1
    fi

    echo "Biome checks passed."
  else
    echo "biome not found, skipping JS/TS checks."
  fi
fi

# ── Rust: fmt + compile check ──
if echo "$STAGED_FILES" | grep -qE '^crates/|^Cargo\.toml|^Cargo\.lock'; then
  echo "Rust changes detected — running checks..."

  MANIFEST="$REPO_ROOT/Cargo.toml"

  if command -v cargo >/dev/null 2>&1; then
    cargo fmt --manifest-path "$MANIFEST" --check 2>/dev/null
    if [ $? -ne 0 ]; then
      echo "cargo fmt: unformatted Rust code. Run 'cargo fmt' to fix."
      exit 1
    fi

    cargo check --manifest-path "$MANIFEST" 2>&1
    if [ $? -ne 0 ]; then
      echo "cargo check: Rust compilation errors found."
      exit 1
    fi

    echo "Rust checks passed."
  else
    echo "cargo not found, skipping Rust checks."
  fi
fi
