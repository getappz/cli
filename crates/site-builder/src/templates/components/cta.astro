---
interface Props {
  headline: string;
  description?: string;
  buttonText: string;
  buttonHref: string;
  variant?: 'default' | 'centered' | 'side';
}

const {
  headline,
  description = '',
  buttonText,
  buttonHref,
  variant = 'default',
} = Astro.props;
---

{variant === 'side' ? (
  <section class="py-16 md:py-24 px-6">
    <div class="max-w-[1200px] mx-auto bg-gradient-to-r from-primary to-primary/80 rounded-2xl p-12 md:p-16 flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="text-white">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-3">{headline}</h2>
        {description && <p class="text-lg opacity-90 max-w-lg">{description}</p>}
      </div>
      <a href={buttonHref} class="shrink-0 inline-block bg-white text-primary px-8 py-4 rounded-xl font-semibold hover:bg-gray-100 transition-all shadow-lg text-lg">
        {buttonText}
      </a>
    </div>
  </section>
) : (
  <section class="py-20 md:py-28 px-6 bg-gradient-to-br from-primary via-primary to-primary/80 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(255,255,255,0.1),transparent)]"></div>
    <div class="relative max-w-3xl mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">{headline}</h2>
      {description && <p class="text-lg mb-10 opacity-90 max-w-xl mx-auto leading-relaxed">{description}</p>}
      <a href={buttonHref} class="inline-block bg-white text-primary px-10 py-4 rounded-xl font-semibold hover:bg-gray-100 transition-all shadow-lg text-lg hover:-translate-y-0.5">
        {buttonText}
      </a>
    </div>
  </section>
)}
