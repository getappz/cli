---
interface FooterLink {
  label: string;
  href: string;
}

interface Props {
  siteName?: string;
  links?: FooterLink[];
  copyright?: string;
}

const {
  siteName = 'Site',
  links = [],
  copyright = '',
} = Astro.props;

const year = new Date().getFullYear();
const copyrightText = copyright || `\u00A9 ${year} ${siteName}. All rights reserved.`;
---

<footer class="bg-gray-900 text-gray-300 mt-auto">
  <div class="max-w-[1200px] mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <div class="font-heading font-bold text-xl text-white mb-3">{siteName}</div>
        <p class="text-sm text-gray-400 leading-relaxed">
          Making a difference, one step at a time.
        </p>
      </div>

      <!-- Quick Links -->
      {links.length > 0 && (
        <div>
          <h4 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">Quick Links</h4>
          <ul class="space-y-2">
            {links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Contact -->
      <div>
        <h4 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">Get In Touch</h4>
        <p class="text-sm text-gray-400 leading-relaxed">
          We'd love to hear from you. Reach out to learn more about our work.
        </p>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-700/50 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-500">{copyrightText}</p>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">Privacy Policy</a>
        <a href="/terms" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">Terms of Use</a>
      </div>
    </div>
  </div>
</footer>
