---
interface Props {
  headline: string;
  subheadline?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  variant?: 'centered' | 'split' | 'image-bg';
  imageUrl?: string;
}

const {
  headline,
  subheadline = '',
  ctaText = '',
  ctaHref = '#',
  secondaryCtaText = '',
  secondaryCtaHref = '#',
  variant = 'centered',
  imageUrl = '',
} = Astro.props;
---

{variant === 'centered' && (
  <section class="relative bg-gradient-to-br from-primary/5 via-background to-accent/5 py-28 md:py-36 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-text-primary">
        {headline}
      </h1>
      {subheadline && (
        <p class="text-lg md:text-xl text-text-secondary mb-10 max-w-2xl mx-auto leading-relaxed">
          {subheadline}
        </p>
      )}
      {ctaText && (
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={ctaHref} class="inline-block bg-primary text-white px-8 py-3.5 rounded-lg font-semibold hover:opacity-90 transition-all shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5">
            {ctaText}
          </a>
          {secondaryCtaText && (
            <a href={secondaryCtaHref} class="inline-block border-2 border-primary text-primary px-8 py-3.5 rounded-lg font-semibold hover:bg-primary/5 transition-all">
              {secondaryCtaText}
            </a>
          )}
        </div>
      )}
    </div>
  </section>
)}

{variant === 'split' && (
  <section class="py-24 md:py-32 px-6 bg-gradient-to-r from-primary/5 to-transparent">
    <div class="max-w-[1200px] mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div>
        <h1 class="font-heading text-4xl md:text-5xl font-bold mb-6 leading-tight text-text-primary">
          {headline}
        </h1>
        {subheadline && <p class="text-lg text-text-secondary mb-8 leading-relaxed">{subheadline}</p>}
        {ctaText && (
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={ctaHref} class="inline-block bg-primary text-white px-8 py-3.5 rounded-lg font-semibold hover:opacity-90 transition-all shadow-lg shadow-primary/25">
              {ctaText}
            </a>
            {secondaryCtaText && (
              <a href={secondaryCtaHref} class="inline-block border-2 border-primary text-primary px-8 py-3.5 rounded-lg font-semibold hover:bg-primary/5 transition-all">
                {secondaryCtaText}
              </a>
            )}
          </div>
        )}
      </div>
      {imageUrl ? (
        <div class="relative">
          <div class="absolute -inset-4 bg-primary/10 rounded-2xl -z-10"></div>
          <img src={imageUrl} alt="" class="w-full rounded-xl shadow-2xl" />
        </div>
      ) : (
        <div class="bg-gradient-to-br from-primary/20 to-accent/20 rounded-2xl aspect-[4/3] flex items-center justify-center">
          <div class="text-center p-8">
            <div class="w-16 h-16 mx-auto mb-4 bg-primary/20 rounded-full flex items-center justify-center">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>
)}

{variant === 'image-bg' && (
  <section
    class="relative py-36 md:py-44 px-6 text-center text-white overflow-hidden"
    style={imageUrl ? `background-image: url(${imageUrl}); background-size: cover; background-position: center;` : ''}
  >
    {!imageUrl && <div class="absolute inset-0 bg-gradient-to-br from-primary to-primary/80"></div>}
    {imageUrl && <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/50 to-black/70"></div>}
    <div class="relative max-w-4xl mx-auto">
      <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight drop-shadow-lg">
        {headline}
      </h1>
      {subheadline && <p class="text-lg md:text-xl mb-10 max-w-2xl mx-auto opacity-90 leading-relaxed">{subheadline}</p>}
      {ctaText && (
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={ctaHref} class="inline-block bg-white text-primary px-8 py-3.5 rounded-lg font-semibold hover:bg-gray-100 transition-all shadow-lg">
            {ctaText}
          </a>
          {secondaryCtaText && (
            <a href={secondaryCtaHref} class="inline-block border-2 border-white text-white px-8 py-3.5 rounded-lg font-semibold hover:bg-white/10 transition-all">
              {secondaryCtaText}
            </a>
          )}
        </div>
      )}
    </div>
  </section>
)}
