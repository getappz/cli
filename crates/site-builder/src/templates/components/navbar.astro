---
interface NavLink {
  label: string;
  href: string;
}

interface Props {
  siteName?: string;
  logoUrl?: string;
  links?: NavLink[];
}

const {
  siteName = 'Site',
  logoUrl = '',
  links = [],
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-background/95 backdrop-blur-md border-b border-black/5 shadow-sm">
  <nav class="max-w-[1200px] mx-auto px-6 py-0 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-3 font-heading font-bold text-xl text-text-primary hover:text-primary transition-colors">
      {logoUrl && <img src={logoUrl} alt={siteName} class="h-9 w-auto" />}
      <span>{siteName}</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-1">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'px-4 py-2 rounded-md text-sm font-medium transition-colors',
            currentPath === link.href
              ? 'text-primary bg-primary/10'
              : 'text-text-secondary hover:text-text-primary hover:bg-black/5',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 rounded-md text-text-secondary hover:text-text-primary hover:bg-black/5 transition-colors"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-black/5 bg-background px-6 pb-4">
    {links.map((link) => (
      <a
        href={link.href}
        class:list={[
          'block py-3 px-4 rounded-md text-sm font-medium transition-colors',
          currentPath === link.href
            ? 'text-primary bg-primary/10'
            : 'text-text-secondary hover:text-text-primary hover:bg-black/5',
        ]}
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
