---
interface Props {
  title?: string;
  subtitle?: string;
  bgColor?: 'default' | 'secondary' | 'primary';
  layout?: 'default' | 'narrow' | 'wide';
}

const {
  title = '',
  subtitle = '',
  bgColor = 'default',
  layout = 'default',
} = Astro.props;

const bgClass = {
  default: 'bg-background',
  secondary: 'bg-gray-50',
  primary: 'bg-primary/5',
}[bgColor] || 'bg-background';

const widthClass = {
  narrow: 'max-w-3xl',
  default: 'max-w-[1200px]',
  wide: 'max-w-[1400px]',
}[layout] || 'max-w-[1200px]';
---

<section class={`py-16 md:py-24 px-6 ${bgClass}`}>
  <div class={`${widthClass} mx-auto`}>
    {title && (
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4 text-text-primary">{title}</h2>
        {subtitle && <p class="text-lg text-text-secondary max-w-2xl mx-auto leading-relaxed">{subtitle}</p>}
        <div class="mt-4 w-16 h-1 bg-primary rounded-full mx-auto"></div>
      </div>
    )}
    <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-text-primary prose-p:text-text-secondary prose-a:text-primary prose-a:no-underline hover:prose-a:underline">
      <slot />
    </div>
  </div>
</section>
