---
interface Quote {
  text: string;
  author: string;
  role?: string;
}

interface Props {
  quotes: Quote[];
}

const { quotes = [] } = Astro.props;
---

<div class="grid md:grid-cols-2 gap-8">
  {quotes.map((quote) => (
    <blockquote class="bg-white rounded-xl border border-gray-100 p-8 shadow-sm relative">
      <div class="absolute -top-3 left-8 text-5xl text-primary/20 font-serif">&ldquo;</div>
      <p class="text-text-secondary leading-relaxed mb-6 text-lg italic">
        {quote.text}
      </p>
      <footer class="flex items-center gap-3">
        <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
          <span class="text-primary font-bold text-sm">{quote.author.charAt(0)}</span>
        </div>
        <div>
          <strong class="text-text-primary font-semibold block">{quote.author}</strong>
          {quote.role && <span class="text-text-secondary text-sm">{quote.role}</span>}
        </div>
      </footer>
    </blockquote>
  ))}
</div>
